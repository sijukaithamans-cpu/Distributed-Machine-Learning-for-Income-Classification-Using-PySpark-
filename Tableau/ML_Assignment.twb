            </column>
            <column caption='Gender' datatype='string' name='[Calculation_2054482377502724]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [SEX] = 1 THEN &quot;Male&quot;&#13;&#10;ELSEIF [SEX] = 2 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
