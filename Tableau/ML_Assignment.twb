    <dashboard enable-sort-zone-taborder='true' name='Dashboard 3 - Income Classification - Feature Importance Interpretation'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='69630' id='13' param='horz' type-v2='layout-flow' w='99002' x='499' y='924'>
            <zone h='69630' id='11' type-v2='layout-basic' w='99002' x='499' y='924'>
